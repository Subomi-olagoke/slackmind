# --- Slack (from api.slack.com/apps -> your app -> Basic Information / OAuth) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- Cortex (sibling memory-server project, ~/Desktop/App lab/cortex) ---
# Run Cortex separately: uvicorn main:app --host 0.0.0.0 --port 8000
CORTEX_API_URL=http://localhost:8000

# --- LLM (optional) ---
# If set, SlackMind calls Claude directly for reply generation + memory
# extraction. If unset, it falls back to Cortex's own /chat endpoint (if
# Cortex has DASHSCOPE_API_KEY configured), and finally to a canned reply —
# the app runs end-to-end either way.
ANTHROPIC_API_KEY=

# --- Misc ---
LOG_LEVEL=INFO
